{
  "name": "@code_shuai/dasheng",
  "version": "1.0.0",
  "description": "🐵 大圣 - 72变无所不能，超越贾维斯的AI助手",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "dasheng": "./bin/dasheng.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest",
    "package": "pkg . --out-path=dist/",
    "prepare": "husky install || true"
  },
  "keywords": [
    "cli",
    "ai",
    "translation",
    "i18n",
    "blog",
    "cover",
    "markdown",
    "yaml",
    "dasheng"
  ],
  "author": "Dasheng Contributors",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "pkg": {
    "scripts": [
      "dist/**/*.js"
    ],
    "assets": [
      "bin/**/*"
    ],
    "targets": [
      "node18-linux-x64",
      "node18-win-x64",
      "node18-macos-x64",
      "node18-macos-arm64"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "canvas": "^2.11.2",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "clipboardy": "^4.0.0",
    "commander": "^11.1.0",
    "dotenv": "^17.3.1",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "gray-matter": "^4.0.3",
    "inquirer": "^9.2.12",
    "js-yaml": "^4.1.0",
    "openai": "^4.28.0",
    "ora": "^7.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "pkg": "^5.8.1",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shuashuai/dasheng.git"
  },
  "bugs": {
    "url": "https://github.com/shuashuai/dasheng/issues"
  },
  "homepage": "https://github.com/shuashuai/dasheng#readme",
  "files": [
    "dist/",
    "bin/",
    "README.md",
    "LICENSE"
  ]
}
